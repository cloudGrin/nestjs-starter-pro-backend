TZ=Asia/Shanghai
WEB_PORT=8088

# Existing MySQL instance. Do not use localhost inside containers.
DB_HOST=
DB_PORT=3306
DB_USERNAME=home
DB_PASSWORD=
DB_DATABASE=home

# Generate both with: openssl rand -base64 32
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

CORS_ORIGIN=*
CORS_CREDENTIALS=false
TRUST_PROXY=true

FILE_BASE_URL=/api/v1/files
FILE_MAX_SIZE=52428800
