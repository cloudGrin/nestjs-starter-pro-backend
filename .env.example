# ========================================
# Home Admin 配置模板
# ========================================
# ⚠️ 安全警告：
# 1. 复制此文件为 .env 并修改配置
# 2. 生产环境密钥必须使用强密码（至少32个字符）
# 3. 不要将包含真实密码的 .env 文件提交到版本控制
# 4. 生产环境配置会进行严格的安全检查
# ========================================

# ========================================
# 应用配置
# ========================================
# 运行环境：development | test | production
NODE_ENV=development
# 服务端口号
PORT=3000
# 应用名称
APP_NAME=home-admin
# API 路径前缀
API_PREFIX=api
# API 版本
API_VERSION=1
# 是否信任反向代理传入的客户端 IP 头
TRUST_PROXY=false

# ========================================
# 数据库配置 (MySQL)
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
# 数据库密码（生产环境必须设置）
DB_PASSWORD=
DB_DATABASE=home
# 是否启用 SQL 日志
DB_LOGGING=false
# 测试环境是否删除数据库（仅在 NODE_ENV=test 时生效）
DB_DROP_SCHEMA=false
# 连接池配置
DB_CONNECTION_LIMIT=10
DB_CONNECTION_TIMEOUT=60000

# ========================================
# JWT 认证配置
# ========================================
# ⚠️ JWT 签名密钥（生产环境必须至少32个字符，使用 openssl rand -base64 32 生成）
JWT_SECRET=dev-secret-key-change-this-in-production
# 访问令牌过期时间（支持 ms 格式：7d, 24h, 60m）
JWT_EXPIRES_IN=7d
# ⚠️ 刷新令牌密钥（必须与 JWT_SECRET 不同，生产环境至少32个字符）
JWT_REFRESH_SECRET=dev-refresh-secret-key-change-this-in-production
# 刷新令牌过期时间
JWT_REFRESH_EXPIRES_IN=30d

# ========================================
# 日志配置
# ========================================
# 日志级别：debug | info | warn | error
LOG_LEVEL=debug
# 日志文件存储目录
LOG_DIR=./logs
# 是否输出到控制台；生产建议保持 true，便于查看首次初始化 admin 密码
LOG_CONSOLE=true

# ========================================
# Swagger API 文档
# ========================================
# 是否启用 Swagger（生产环境必须为 false）
SWAGGER_ENABLE=true
SWAGGER_TITLE=Home Admin API
SWAGGER_DESCRIPTION=Home Admin API Documentation
SWAGGER_VERSION=1.0.0
# 文档访问路径
SWAGGER_PATH=api-docs

# ========================================
# 跨域配置
# ========================================
# ⚠️ 允许的来源（生产环境禁止使用 *，必须指定具体域名）
# 多个域名用逗号分隔：https://example.com,https://app.example.com
CORS_ORIGIN=*
# 是否发送 Cookie
CORS_CREDENTIALS=false

# ========================================
# 限流配置
# ========================================
# 时间窗口（秒）
THROTTLE_TTL=60
# 时间窗口内最大请求数
THROTTLE_LIMIT=100

# ========================================
# 文件上传配置
# ========================================
# 存储方式：local | oss
FILE_STORAGE=local
# 本地文件存储目录
FILE_UPLOAD_DIR=uploads
# 本地公开文件下载基础 URL；如有域名可改为 https://example.com/api/v1/files
FILE_BASE_URL=/api/v1/files
# 最大文件大小（字节），默认 50MB
FILE_MAX_SIZE=52428800
# 允许的文件类型（逗号分隔）
FILE_ALLOWED_TYPES=.jpg,.jpeg,.png,.gif,.webp,.pdf,.doc,.docx,.ppt,.pptx,.txt,.zip

# ========================================
# 阿里云 OSS 配置（可选）
# ========================================
FILE_OSS_ENABLE=false
FILE_OSS_REGION=
FILE_OSS_BUCKET=
FILE_OSS_ENDPOINT=
FILE_OSS_ACCESS_KEY_ID=
FILE_OSS_ACCESS_KEY_SECRET=
# 是否使用 HTTPS
FILE_OSS_SECURE=true
# CDN 或自定义域名
FILE_OSS_BASE_URL=

# ========================================
# 通知配置
# ========================================
# Bark 推送（iOS）
NOTIFY_BARK_ENABLE=false
NOTIFY_BARK_BASE_URL=
NOTIFY_BARK_DEFAULT_KEY=

# 飞书机器人
NOTIFY_FEISHU_ENABLE=false
NOTIFY_FEISHU_WEBHOOK=
