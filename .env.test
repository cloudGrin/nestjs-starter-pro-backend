# E2E测试环境变量配置

# Application
NODE_ENV=test
PORT=3000
APP_NAME=home-server-test

# Database - 使用Docker容器中的MySQL
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3307
DB_USERNAME=home_test
DB_PASSWORD=test_password
DB_DATABASE=home_test
DB_SYNCHRONIZE=false
DB_DROP_SCHEMA=false
DB_LOGGING=false

# Redis - 使用Docker容器中的Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
REDIS_PASSWORD=test_redis_password

# JWT
JWT_SECRET=test-secret-key-for-e2e-testing
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=test-refresh-secret-key-for-e2e-testing
JWT_REFRESH_EXPIRES_IN=30d

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# API
API_PREFIX=api
API_VERSION=1
API_RATE_LIMIT=1000

# Swagger
SWAGGER_ENABLE=false

# CORS
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true
CAPTCHA_REQUIRE_LOGIN=false
