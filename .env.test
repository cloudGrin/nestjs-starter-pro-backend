# E2E测试环境变量配置

# Application
NODE_ENV=test
PORT=3000
APP_NAME=home-server-test

# Database - 使用Docker容器中的MySQL
DB_HOST=localhost
DB_PORT=3307
DB_USERNAME=home_test
DB_PASSWORD=test_password
DB_DATABASE=home_test
DB_DROP_SCHEMA=false
DB_LOGGING=false

# JWT
JWT_SECRET=test-secret-key-for-e2e-testing
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=test-refresh-secret-key-for-e2e-testing
JWT_REFRESH_EXPIRES_IN=30d

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# API
API_PREFIX=api
API_VERSION=1

# Swagger
SWAGGER_ENABLE=false

# CORS
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true
