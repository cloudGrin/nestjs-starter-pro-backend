# ========================================
# home Server 配置模板
# ========================================
# ⚠️ 安全警告：
# 1. 复制此文件为 .env 并修改配置
# 2. 生产环境密钥必须使用强密码（至少32个字符）
# 3. 不要将包含真实密码的 .env 文件提交到版本控制
# 4. 生产环境配置会进行严格的安全检查
# ========================================

# ========================================
# 应用配置
# ========================================
# 运行环境：development | test | production
NODE_ENV=development
# 服务端口号
PORT=3000
# 应用名称
APP_NAME=home-server
# API 路径前缀
API_PREFIX=api
# API 版本
API_VERSION=1

# ========================================
# 数据库配置 (MySQL)
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
# 数据库密码（生产环境必须设置）
DB_PASSWORD=
DB_DATABASE=home
# 是否启用 SQL 日志
DB_LOGGING=false
# 测试环境是否删除数据库（仅在 NODE_ENV=test 时生效）
DB_DROP_SCHEMA=false
# 连接池配置
DB_CONNECTION_LIMIT=10
DB_CONNECTION_TIMEOUT=60000
DB_ACQUIRE_TIMEOUT=60000
DB_QUERY_TIMEOUT=60000

# ========================================
# JWT 认证配置
# ========================================
# ⚠️ JWT 签名密钥（生产环境必须至少32个字符，使用 openssl rand -base64 32 生成）
JWT_SECRET=dev-secret-key-change-this-in-production
# 访问令牌过期时间（支持 ms 格式：7d, 24h, 60m）
JWT_EXPIRES_IN=7d
# ⚠️ 刷新令牌密钥（必须与 JWT_SECRET 不同，生产环境至少32个字符）
JWT_REFRESH_SECRET=dev-refresh-secret-key-change-this-in-production
# 刷新令牌过期时间
JWT_REFRESH_EXPIRES_IN=30d

# ========================================
# 日志配置
# ========================================
# 日志级别：debug | info | warn | error
LOG_LEVEL=debug
# 日志文件存储目录
LOG_DIR=./logs

# ========================================
# Swagger API 文档
# ========================================
# 是否启用 Swagger（生产环境建议设为 false）
SWAGGER_ENABLE=true
SWAGGER_TITLE=home API
SWAGGER_DESCRIPTION=home Backend Management System API Documentation
SWAGGER_VERSION=1.0.0
# 文档访问路径
SWAGGER_PATH=api-docs

# ========================================
# 跨域配置
# ========================================
# ⚠️ 允许的来源（生产环境禁止使用 *，必须指定具体域名）
# 多个域名用逗号分隔：https://example.com,https://app.example.com
CORS_ORIGIN=*
# 是否发送 Cookie
CORS_CREDENTIALS=false

# ========================================
# 限流配置
# ========================================
# 时间窗口（秒）
THROTTLE_TTL=60
# 时间窗口内最大请求数
THROTTLE_LIMIT=100

# ========================================
# 文件上传配置
# ========================================
# 存储方式：local | oss
FILE_STORAGE=local
# 本地文件存储目录
FILE_UPLOAD_DIR=uploads
# 临时文件目录
FILE_TEMP_DIR=uploads/temp
# 文件访问基础 URL
FILE_BASE_URL=/uploads
# 最大文件大小（字节），默认 50MB
FILE_MAX_SIZE=52428800
# 允许的文件类型（逗号分隔）
FILE_ALLOWED_TYPES=.jpg,.jpeg,.png,.gif,.webp,.svg,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.zip

# 分片上传配置
# 默认分片大小（字节），默认 5MB
FILE_CHUNK_SIZE=5242880
# 分片信息过期时间（秒），默认 24 小时
FILE_CHUNK_EXPIRE=86400

# 图片处理配置
# 是否压缩图片
FILE_IMAGE_COMPRESS=false
# 压缩质量（1-100）
FILE_IMAGE_QUALITY=80
# 最大宽度（像素）
FILE_IMAGE_MAX_WIDTH=1920
# 是否生成缩略图
FILE_IMAGE_THUMBNAIL_ENABLE=false
# 缩略图宽度
FILE_IMAGE_THUMBNAIL_WIDTH=320
# 缩略图高度
FILE_IMAGE_THUMBNAIL_HEIGHT=320

# ========================================
# 阿里云 OSS 配置（可选）
# ========================================
FILE_OSS_ENABLE=false
FILE_OSS_REGION=
FILE_OSS_BUCKET=
FILE_OSS_ENDPOINT=
FILE_OSS_ACCESS_KEY_ID=
FILE_OSS_ACCESS_KEY_SECRET=
# 是否使用 HTTPS
FILE_OSS_SECURE=true
# CDN 或自定义域名
FILE_OSS_BASE_URL=

# ========================================
# 通知配置
# ========================================
# Bark 推送（iOS）
NOTIFY_BARK_ENABLE=false
NOTIFY_BARK_BASE_URL=
NOTIFY_BARK_DEFAULT_KEY=

# 飞书机器人
NOTIFY_FEISHU_ENABLE=false
NOTIFY_FEISHU_WEBHOOK=
