# 注意：实际使用时应该将敏感信息存储在安全的地方（如Sealed Secrets、Vault等）
# 本文件仅作为示例，不要提交到Git仓库

apiVersion: v1
kind: Secret
metadata:
  name: home-secret
  namespace: default
type: Opaque
stringData:
  # 数据库认证（需要替换为实际值）
  db.username: "home"
  db.password: "home_password_changeme"

  # Redis认证（需要替换为实际值）
  redis.password: "redis_password_changeme"

  # JWT密钥（需要替换为实际值，建议使用强随机字符串）
  jwt.secret: "your-jwt-secret-key-changeme-in-production"
  jwt.refresh-secret: "your-jwt-refresh-secret-key-changeme"

---
# 如果使用base64编码（推荐在生产环境）
# 生成方法: echo -n "your-secret" | base64
apiVersion: v1
kind: Secret
metadata:
  name: home-secret-encoded
  namespace: default
type: Opaque
data:
  # 示例（需要替换为实际base64编码值）
  db.username: cGFuZ3U=  # home
  db.password: cGFuZ3VfcGFzc3dvcmRfY2hhbmdlbWU=  # home_password_changeme
  redis.password: cmVkaXNfcGFzc3dvcmRfY2hhbmdlbWU=  # redis_password_changeme
  jwt.secret: eW91ci1qd3Qtc2VjcmV0LWtleS1jaGFuZ2VtZS1pbi1wcm9kdWN0aW9u  # your-jwt-secret-key-changeme-in-production
  jwt.refresh-secret: eW91ci1qd3QtcmVmcmVzaC1zZWNyZXQta2V5LWNoYW5nZW1l  # your-jwt-refresh-secret-key-changeme
